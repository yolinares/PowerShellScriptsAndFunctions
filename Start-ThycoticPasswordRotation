function Start-ThycoticPasswordRotation {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretID,

        [string]
        $NewPassword,

        #[parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        #[parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = "/api/v1/secrets/$SecretID/change-password"
    $uri = $uriBuilder.Uri.ToString()
    
    $bodyArgs = @{}
    if ($NewPassword) {
        $bodyArgs.body = @{newPassword = $NewPassword} | ConvertTo-Json
    }
    
    Invoke-RestMethod -Uri $uri @body -Method Post -Headers $ThycoticAuthenticationToken -ContentType "application/json"
} 
