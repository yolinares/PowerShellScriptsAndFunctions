function CheckIn-ThycoticSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretID,

        [bool]
        $ForceCheckIn,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl)
    $uriBuilder.Path = "/api/v1/secrets/$SecretID/check-in"
    $uri = $uriBuilder.Uri.ToString()

    $invokeBody = @{
        forceCheckIn = $ForceCheckIn
    } | ConvertTo-Json

    Invoke-RestMethod -Uri $uri -Body $invokeBody -Method Post -Headers $ThycoticAuthenticationToken -ContentType "application/json"
}
