function Delete-VaultSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [string]
        $NameSpacePath,

        [parameter(Mandatory)]
        [string]
        $SecretPath,

        [parameter(Mandatory)]
        [string]
        $SecretName,

        [parameter(Mandatory)]
        [uri]
        $VaultUrl,

        [parameter(Mandatory)]
        [hashtable]
        $VaultAuthenticationHeader
    )

    if ($SecretPath -notlike "secret/*") {
        $vaultSecretPath = "secret/$SecretPath"
    }
    else {
        $vaultSecretPath = $SecretPath
    }

    $uriBuilder = [System.UriBuilder]::new($VaultUrl)
    $uriBuilder.Path = "v1/$NameSpacePath/$vaultSecretPath/$SecretName"
    $uri =  $uriBuilder.Uri.ToString()
    
    Invoke-RestMethod -Uri $uri -Method Delete -Headers $VaultAuthenticationHeader
}
