function Remove-ThycoticSecretPermission {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretPermissionID,

        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = "/api/v1/secret-permissions/$SecretPermissionID"
    $uri = $uriBuilder.Uri.ToString()

    Invoke-RestMethod -Uri $uri -Method Delete -Headers $ThycoticAuthToken
}
