function New-ThycoticSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [Alias("arg.name")]
        [string]
        $SecretName,

        [string]
        $Domain,

        [string]
        $UserName,

        [parameter(Mandatory)]
        [string]
        $AccountOwner,

        [string]
        $Password = [System.Web.Security.Membership]::GeneratePassword(16,5),

        [Alias("arg.siteId")]
        [int]
        $SiteID,

        [Alias("arg.autoChangeEnabled")]
        [switch]
        $AutoChangePassword,

        [Alias("arg.checkOutEnabled")]
        [switch]
        $EnableCheckOut,

        [Alias("arg.checkOutIntervalMinutes")]
        [int]
        $MinutesPerCheckoutSession,

        [Alias("arg.checkOutChangePasswordEnabled")]
        [switch]
        $ChangePasswordOnCheckin,

        [Alias("arg.enableInheritPermissions")]
        [bool]
        $InheritFolderPermissions,

        [Alias("arg.enableInheritSecretPolicy")]
        [bool]
        $InheritFolderSecretPolicy,

        [Alias("arg.secretPolicyId")]
        [int]
        $SecretPolicyId,

        [parameter(Mandatory)]
        [Alias("q.SecretTemplateId")]
        [int]
        $SecretTemplateId,
        
        [parameter(Mandatory)]
        [Alias("q.FolderId")]
        [int]
        $FolderId,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $queryString = [Web.HttpUtility]::ParseQueryString('')

    $MyInvocation.MyCommand.Parameters.GetEnumerator() | 
        where {$_.Value.Aliases -like "q.*" -and $PSBoundParameters.Keys -contains $_.Key} |
        foreach {
            $queryString[$_.Value.Aliases[0].replace('q.','')] = $PSBoundParameters[$_.Key]
        }

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = '/api/v1/secrets/stub'
    $uriBuilder.Query = $queryString.ToString()
    $uri = $uriBuilder.Uri.ToString()


    try {
        $secretsStub = Invoke-RestMethod -Uri $uri -Method Get -Headers $ThycoticAuthenticationToken
    }
    catch {
        throw $_
    }

    #This will take any parameter that has an alias of  arg. and set the value in the stub
    #If the parameter is not given a value then the default value from the stub is used.
    $MyInvocation.MyCommand.Parameters.GetEnumerator() | 
        where {$_.Value.Aliases -like "arg.*" -and $PSBoundParameters.Keys -contains $_.Key} |
        foreach {
            $secretsStub.($_.Value.Aliases[0].replace('arg.','')) = $PSBoundParameters[$_.Key]
        }

    $secretsStub.items | foreach {
        if ($_.fieldName -eq "Domain") {
            $_.itemValue = $Domain
        }
            
        if ($_.fieldName -eq "Username") {
            $_.itemValue = $UserName
        }
            
        if ($_.fieldName -eq "Account Owner") {
            $secretOwner = Get-ADUser -Filter "SamAccountName -eq '$($AccountOwner)'"
            if ($null -ne $secretOwner) {
                $secretOwnerString = "$($secretOwner.GivenName) $($secretOwner.Surname) ($($secretOwner.SamAccountName))"
                $secretOwnerStringNormalized = (($secretOwnerString.Normalize([System.Text.NormalizationForm]::FormD)).ToCharArray() | 
                    where {[Globalization.CharUnicodeInfo]::GetUnicodeCategory($_) -ne [Globalization.UnicodeCategory]::NonSpacingMark}) -join ""
                $_.itemValue = $secretOwnerStringNormalized
            }
            else {
                $_.itemValue = $AccountOwner
            }
        }

        if ($_.fieldName -eq "Password") {
            $_.itemValue = $Password
        }
    }

    $invokeBody = $secretsStub | ConvertTo-Json -Depth 10

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = '/api/v1/secrets'
    $uri = $uriBuilder.Uri.ToString()

    Invoke-RestMethod -Uri $uri -Method Post -Body $invokeBody -Headers $ThycoticAuthenticationToken -ContentType "application/json"
}