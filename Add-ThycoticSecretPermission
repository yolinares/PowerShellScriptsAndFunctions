function Add-ThycoticSecretPermission {
    [CmdletBinding(DefaultParameterSetName="Default")]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretID,
        
        [parameter(Mandatory,ParameterSetName="User")]
        [int]
        $UserId,
        
        [parameter(Mandatory,ParameterSetName="Group")]
        [int]
        $GroupId,
        
        [parameter(Mandatory)]
        [ValidateSet("Owner","Edit","View")]
        [string]
        $AccessLevel,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = '/api/v1/secret-permissions/stub'
    $uriBuilder.Query = "secretId=$SecretID"
    $uri = $uriBuilder.Uri.ToString()
    
    $permissionStub = Invoke-RestMethod -Uri $uri -Method Get -Headers $ThycoticAuthenticationToken
    
    if ($UserId) {
        $permissionStub.userId = $UserId
    }
        
    if ($GroupId) {
        $permissionStub.groupId = $GroupId
        $permissionStub.userId = $null
    }

    $permissionStub.secretAccessRoleName = $AccessLevel
    
    $invokeBody = $permissionStub | ConvertTo-Json

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = '/api/v1/secret-permissions/'
    $uri = $uriBuilder.Uri.ToString()

    Invoke-RestMethod -Uri $uri -Method Post -Body $invokeBody -Headers $ThycoticAuthenticationToken -ContentType "application/json"
}
