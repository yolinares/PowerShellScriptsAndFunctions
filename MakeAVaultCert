function MakeAVaultCert {
    <#
    .SYNOPSIS

    Creates a Certificate from a Vault CA
 
    .DESCRIPTION

    Will create and import a certificate froma  Vault CA. Can be used to keep IIS certs up to date and or upload certs to AWS
 
    .OUTPUTS

    Nothing
            
    .PARAMETER SubjectName
            
    The subjectName for the certificate. This will generally be the websitename. This value MUST be defined under AllowedDomains in the vault.yaml file for the namespace.
    The entries ARE Capitalization sensitive and its recommended to leave all entries lowercase. The function will send all subjectnames in lowercase to vault.
    Example SubjectName: www.google.com

    Example vault.yaml Entries:
        Version: 1

        Notifications:
          Email: Example_DL@domain.com

        Admins:
          - ID: I123456
            Email: Example_User@domain.com

        Roles:
          exampleRole:
            AWS:
              IAMRoles:
                - Example-IAM-Role
            AllowedDomains:
              - demo.example.server.fqdn # Standard format for most certs - Exact match for a server cert - no subdomains
              - demo-*.example.server.fqdn # Wildcard after an enforced prefix - acceptable but not preferred
            
            
    .PARAMETER SanNames
            
    Subject Alternatie Names for the certificate. This is any additional alternate name for your site/service you whish to secure with the certificate.
            
    Example vault.yaml Entries:
        Version: 1

        Notifications:
          Email: Example_DL@domain.com

        Admins:
          - ID: I123456
            Email: Example_User@domain.com

        Roles:
          exampleRole:
            AWS:
              IAMRoles:
                - Example-IAM-Role
            AllowedDomains:
              - demo.example.server.fqdn # Standard format for most certs - Exact match for a server cert - no subdomains
              - demo-*.example.server.fqdn # Wildcard after an enforced prefix - acceptable but not preferred


    .PARAMETER HashAlgorithm
            
    The HashAlgorithm you wish to use to encrypt the certificate with. Recommend leaving at the default sha256
            

    .PARAMETER KeyLength
            
    The length of the key for the certificate. Recommend leaving at 2048. At the time of writing this, vault support key lengths of 2048,4096, and 8192


    .PARAMETER CertTTL
            
    How long you want the cert to live for. defined as h for hours and m for minutes
    Example: a 90 day cert would be defined as 2160h (24 hours X 90 days)
            

    .PARAMETER CertExpirationThreshold
            
    How many days left on the cert before you replace it. Default is 7 days meaning if the cert is going to expire in the next 7 days, and the subjectName matches the set subjectName, then a new certificate will be replaced.


    .PARAMETER InstallIISCert
            
    Defines if you want to update the certificate for a binding in IIS. The IIS Site MUST BE CREATED ALREADY to use this parmeter


    .PARAMETER iisSiteName
    If you use the InstallIISCert parameter you will need to define the site name that IIS will use.


    .PARAMETER iisPort
    If you use the InstallIISCert parmeter you will need to define the port that site uses. Defaults to 443
            

    .PARAMETER VaultAuthMethod
            
    The Authentication Method for connecting to Vault
    Acceptable values are: awsIAM, Credentials, Token


    .PARAMETER VaultNameSpace
            
    If you select awsIAM for VaultAuthMethod you will need to define the VaultNameSpace
    The Namespace and any sub folders that contains the vault.yaml file .
    Example: bastion/ExampleSubFolder1                                                            


    .PARAMETER AWSRegion
            
    If you select awsIAM for VaultAuthMethod you will need to define the AWS Region that you want to connect to
    Default: Uses the output of: (Invoke-RestMethod -Uri http://169.254.169.254/latest/dynamic/instance-identity/document -Method Get).region
    If a region cannot be determined the function will stop and throw and error.
            

    .PARAMETER YamLRole
    If you select awsIAM for VaultAuthMethod you will need to define the YamL role that is defined in the yaml.vault file for the namespace

    Example Vault.YamL File:
        Version: 1

        Notifications:
          Email: Example_DL@sap.com

        Admins:
          - ID: I123456
            Email: Example_User@sap.com

        Roles:
          exampleRole: <----- yaml Role Name
            AWS:
              IAMRoles:
                - Example-IAM-Role
            AllowedDomains:
              - example.domain.com


    .PARAMETER VaultCredentials

    If you select Credentials for VaultAuthMethod you will need to define the Credentials used to Authenticate to Vault
            

    .PARAMETER VaultToken

    If you select Token for VaultAuthMethod you will need to define the Token used to Authenticate to Vault

            
    .PARAMETER VaultURL
            
    The URL for Vault. 
            
    Default: https://vault.domain.com


    .PARAMETER AWSIamProfile

    The IAM Profile assigned to the EC2 instnace. 
    The function uses the outout of (Invoke-RestMethod -Uri http://169.254.169.254/latest/meta-data/iam/security-credentials)
    To:
    1 - Set the AWSIamProfile it it isn't defined
    2 - Verify the AWSIamProfile if it IS defined

    The Iam Profile also must be defined in the vault.yaml for that namespace
            
    Example vault.yaml file:
    Version: 1

    Notifications:
        Email: Example_DL@domain.com

    Admins:
      - ID: I123456
        Email: Example_User@domain.com

    Roles:
      exampleRole:
        AWS:
          IAMRoles:
            - Example-IAM-Role <----- This should be the IAM role assigned to the EC2 instance
        AllowedDomains:
          - example.domain.com
            

    .PARAMETER UploadToAWS

    Uploads the certificate to the AWS CertManager Store. Uses the attached IAM role to upload the certificate. 
    Make sure that the attached IAM role has the rights to upload certificates to AWS

    This also marks the certificate as exportable


    .PARAMETER Exportable

    Set if the certificate should be exportable or not. If you use the UploadToAWS paramter the certificate will be marked as exportable


    .PARAMETER ExportToFile

    Will export the cert, key and cert chain to a Pem formated file. The files will be stored in the working directory. If this parameter is set then the certificate will also automatically be marked as exportalbe.
    Files will be stored as SubjectName_(cert/key/chain).pem


    .PARAMETER RemoveExpiredCerts

    Removes any expired certificate with the same subjectName


    .PARAMETER WorkingFolderPath
            
    Path to the folder where the certificate files will be exported if ExportToFile is set
    Default: C:\Certificates\<SubjectName (stripped of all special characters)>_<DateTimeStamp>\


    .PARAMETER LogFolderPath
            
    Path to the folder where powershell outputs its logs to.
    Default: C:\Logs\<SubjectName (stripped of all special characters)>\


    .PARAMETER Quite
            
    Will stop logging from being written the console


    .PARAMETER Force

    Force a cert to be generated and installed


    .Example

    The minimum information needed to create a certificate.
    Creates a 90 day (default) certificate for thycotic.service.cnqr.tech authenticating to vault using IAM auth.

    MakeAVaultCert -SubjectName "thycotic.domain.com" -VaultAuthMethod awsIAM -YamLRole exampleRole -VaultNameSpace exampleNamespace


    .Example

    Creates a 30 day certificate for thycotic.service.cnqr.tech with SubjectAlternateNames of thycoticSS1.service.cnqr.tech and thycoticSS2.service.cnqr.tech. Authenticates to Vault using IAM Auth and install them to the Default Web Site in IIS

    MakeAVaultCert -SubjectName "thycotic.domain.com" -SanNames "thycoticFE001.domain.com" -CertTTL "720h" -VaultAuthMethod awsIAM -YamLRole exampleRole -VaultNameSpace exampleNamespace -InstallIISCert -iisSiteName 'Default Web Site'


    .Example

    Creates a 30 day certificate for thycotic.service.cnqr.tech. It authenticates to https://vault.nonstandard.Url.com using the IAM Profile of EC2Admin

    MakeAVaultCert -SubjectName "thycotic.domain.com" -CertTTL "720h" -VaultAuthMethod awsIAM -YamLRole exampleRole -VaultNameSpace exampleNamespace -VaultURL "https://vault.nonstandard.Url.com" -AWSIamProfile "ExampleProfile"

    #>
    [CmdletBinding(DefaultParameterSetName="Default")]
    param(
        #need to remove the false flage when testing
        [parameter(Mandatory = $true)]
        [string]
        $SubjectName,

        [parameter()]
        $SanNames,

        [parameter()]
        [string]
        $HashAlgorithm = "sha256",

        [parameter()]
        [ValidateSet(2048,4096,8192)]
        [long]
        $KeyLength = "2048",

        [parameter(HelpMessage="Enter Cert TLL in Hours (h) or Minutes (m). Example: 2160h for 90 days")]
        [string]
        $CertTTL = "2160h",

        [parameter()]
        [int]
        $CertExpirationThreshold = 7,

        [parameter()]
        [Switch]
        $InstallIISCert = $false,

        #need to remove the false flage when testing
        [parameter(Mandatory = $true)]
        [ValidateSet("awsIAM","Credentials","Token")]
        [String]
        $VaultAuthMethod,
        
        [parameter(Mandatory = $true)]
        [String]
        $VaultNameSpace,
        
        [parameter(Mandatory = $true)]
        [String]
        $YamLRole,

        #need to remove the false flage when testing
        [parameter()]
        [ValidateScript({Test-NetConnection -Port 443 $_.Host -InformationLevel Quiet})]
        [uri]
        $VaultURL = "https://vault.domain.com",

        [parameter()]
        [String]
        $AWSIamProfile,

        [parameter()]
        [Switch]
        $UploadToAWS = $false,

        [parameter()]
        [Switch]
        $Exportable = $false,

        [parameter()]
        [Switch]
        $ExportToFile = $false,

        [parameter()]
        [Switch]
        $RemoveExpiredCerts = $false,

        [parameter()]
        $WorkingFolderPath,

        [parameter()]
        $LogFolderPath,
        
        [parameter()]
        [Switch]
        $Quiet = $false,
        
        [parameter()]
        [Switch]
        $Force = $false
    )

    DynamicParam {
        $paramDictionary = New-Object System.Management.Automation.RuntimeDefinedParameterDictionary

        if ($InstallIISCert -eq $true) {
            #Add IIS Site Name Parameter
            #Name of the Parameter
            $paramName = "iisSiteName"
            
            #Create Attribute and Attributecollection objects
            $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
            $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

            #Define and add Parameter Attributes
            $paramAttribute.Mandatory = $true
            $attributeCollection.Add($paramAttribute)            
            
            #if running in admin mode it will auto populate a list of IIS sites on the server if they exist.
            if (([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator") -eq $true) {
                #checks to see if the WebAdministration module is available
                if ((Get-Module -ListAvailable -Name WebAdministration)) {
                    #Get a list of sites to populate for the validate data
                    $ValidateSetData = (Get-IISSite).Name
                    $ValidateSetAttribute = New-Object System.Management.Automation.ValidateSetAttribute($ValidateSetData)
                    #Adds the ValidateSet to the Param
                    $attributeCollection.Add($ValidateSetAttribute)
                }
            }

            #Create the parameter and add it to the dynamic parameters
            $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName, [String], $attributeCollection)
            $paramDictionary.Add($paramName,$param)

            #####################################################################################################

            #Add AWSRegion Parameter
            #Name of the Parameter
            $paramName = "iisPort"
            
            #Create Attribute and Attributecollection objects
            $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
            $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

            #Define and add Parameter Attributes
            $attributeCollection.Add($paramAttribute)
            
            #Create the parameter and add it to the dynamic parameters
            $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName, [int], $attributeCollection)
            $param.Value = "443"
            $paramDictionary.Add($paramName,$param)
        }

        if ($VaultAuthMethod -eq "awsIAM") {
            #Add AWSRegion Parameter
            #Name of the Parameter
            $paramName = "AWSRegion"
            
            #Create Attribute and Attributecollection objects
            $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
            $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

            #Define and add Parameter Attributes
            $attributeCollection.Add($paramAttribute)
            
            #Create the parameter and add it to the dynamic parameters
            $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName, [String], $attributeCollection)
            $paramDictionary.Add($paramName,$param)

            #####################################################################################################
        }

        if ($VaultAuthMethod -eq "Credentials") {
            #Name of the Parameter
            $paramName = "VaultCredentials"
            
            #Create Attribute and Attributecollection objects
            $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
            $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

            #Define and add Parameter Attributes
            $paramAttribute.Mandatory = $true
            $attributeCollection.Add($paramAttribute)

            $paramValidateNotNull = New-Object System.Management.Automation.ValidateNotNullAttribute
            $attributeCollection.Add($paramValidateNotNull)            
            
            #Create the parameter and add it to the dynamic parameters
            $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName,[System.Management.Automation.PSCredential], $attributeCollection)
            #default Value
            $param.Value = [System.Management.Automation.PSCredential]::Empty

            $paramDictionary.Add($paramName,$param)

            #####################################################################################################
        }

        if ($VaultAuthMethod -eq "Token") {
            #Name of the Parameter
            $paramName = "$VaultToken"
            
            #Create Attribute and Attributecollection objects
            $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
            $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

            #Define and add Parameter Attributes
            $paramAttribute.Mandatory = $true
            $attributeCollection.Add($paramAttribute)

            #Create the parameter and add it to the dynamic parameters
            $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName, [String], $attributeCollection)

            $paramDictionary.Add($paramName,$param)
        }

        return $paramDictionary
    }

    Begin 
    {
        #############################
        #Defaults that need to be vefired before the function can even work
        #############################
        
        $ErrorActionPreference = "Stop"

        #Check if running in Admin Mode
        $AdminModeCheck = ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")
        if ($AdminModeCheck -eq $false) {
            Throw "Powershell is not running in Admin mode. Please launch PowerShell with run as Admin"
        }

        #force TLS1.2
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
        
        #############################
        #ScriptFunctions
        #############################

        #Originally taken from:
        #https://gallery.technet.microsoft.com/scriptcenter/Write-Log-PowerShell-999c32d0
        function Write-Log  { 
            [CmdletBinding()]
            Param  ( 
                [Parameter(Mandatory, 
                ValueFromPipelineByPropertyName=$true,
                ValueFromPipeline = $true)]
                [string]
                $Message, 
                
                [Parameter()]
                [string]
                $LogName = $logFileName,

                [Parameter()]
                [string]
                $LogFolder = $LogFolderPath,

                [Parameter()]
                [ValidateSet("Error","Warn","Info")]
                [string]
                $Level="Info",

                [Parameter()]
                [String]
                $InfoTextColor,

                [Parameter()]
                [Switch]
                $ThrowError = $false,

                [Parameter()]
                [Switch]
                $Quiet = $Quiet.IsPresent
            )

            Begin  { 
                # Set VerbosePreference to Continue so that verbose messages are displayed. 
                $VerbosePreference = 'Continue' 
                if ($InfoTextColor -and ($InfoTextColor -in [Enum]::GetValues([ConsoleColor])) ) {
                    $foregroundColor = @{
                        ForegroundColor = $InfoTextColor
                    }
                }

                if (!($LogName)) {
                    $LogName = "PowerShellLog_$(Get-date -Format FileDateTimeUniversal).txt"
                }

                if (!($LogFolder)) {
                    $LogFolder = "C:\Logs\"
                }

                $LogPath = Join-Path -Path $LogFolder -ChildPath $LogName
            }
             
            Process  {
                # If attempting to write to a log file in a folder/path that doesn't exist create the file including the path. 
                if (!(Test-Path $LogPath)) { 
                    Write-Verbose "Creating: $LogPath." 
                    New-Item $LogPath -Force -ItemType File | Out-Null
                }

                # Format Date for our Log File 
                $FormattedDate = Get-Date -Format "yyyy-MM-dd HH:mm:ss" 
 
                # Write message to error, warning, or verbose pipeline and specify $LevelText 
                switch ($Level) { 
                    'Error' { 
                        $LevelText = 'ERROR:'
                        if ($ThrowError -eq $false) {
                            if ($Quiet -eq $false) {
                                Write-Host -Object $Message -ForegroundColor Red
                            }
                        }
                        else {
                            # Write log entry to $LogPath
                            # Ensures errors get written to the log
                            if ($ErrorActionPreference -in @("Stop","Inquire") ) {
                                "$FormattedDate $LevelText $Message" | Out-File -FilePath $LogPath -Append
                            }
                                
                            Write-Error -Message $Message
                        }
                    }
                    'Warn' { 
                        $LevelText = 'WARNING:'
                        if ($Quiet -eq $false)
                        {
                            Write-Host -Object $Message -ForegroundColor Yellow
                        }
                    }
                    'Info' {
                        $LevelText = 'INFO:'
                        if ($Quiet -eq $false)
                        {
                            Write-Host $Message @foregroundColor
                        }
                    }
                }
         
                # Write log entry to $LogPath
                "$FormattedDate $LevelText $Message" | Out-File -FilePath $LogPath -Append
            }

            End {
            }
        }

        function Normalize-Uri {
            param (
                [parameter(
                    Mandatory,
                    Position = 0,
                    ValueFromPipeline = $True
                )]
                [uri]
                $Uri
            )

            $uriPath = ($Uri.Segments | where {$_ -ne '/'}).Trim() -join ''

            $uriBuilder = [System.UriBuilder]::new($uri.Scheme,$Uri.Host,$uri.Port,$uriPath)

            [uri]$NormalizedUri = $uriBuilder.Uri

            Return $NormalizedUri.AbsoluteUri
        }

        function EncodeTo-Base64 {
            param (
                $ValueToEncode
            )
            
            $byteArray = [System.Text.Encoding]::UTF8.GetBytes($ValueToEncode)
            $out = [System.Convert]::ToBase64String($byteArray)

            return $out
        }

        function Build-ASWSignedRequest {
            param (
                $AwsIAMRole,
                $Algorithm = 'AWS4-HMAC-SHA256',
                $Method = 'POST',
                $Service,
                $awsHost,
                $Region,
                $awsRequestParmeters,
                $awsQueryString,
                $SignedHeaders,
                $X_Amz_Target,
                $Content_Type
            )

            function getSHA256 {
                param (
                    $data
                )
    
                $hash = [System.Security.Cryptography.SHA256]::Create()
                $hashData = $hash.ComputeHash( [System.Text.Encoding]::UTF8.GetBytes($data) )
                $output = ($hashData | foreach ToString X2).ToLower()  -join ''
                return $output

            }

            # inspired by https://gallery.technet.microsoft.com/scriptcenter/Get-StringHash-aa843f71
            function HmacSHA256 {
                param (
                    $data,
                    $key,
                    [switch]$StringOut
                )
    
                $hmacsha = New-Object System.Security.Cryptography.HMACSHA256    
                $hmacsha.key = $key    
                $sign = $hmacsha.ComputeHash([Text.Encoding]::UTF8.GetBytes($data))
                if ($StringOut -eq $false) {
                    return $sign
                }
                else {
                    $out = ($sign | foreach ToString X2).tolower() -join ''
                    return $out
                }
            }

            function getSignatureKey {
                param (
                    [String]
                    $key,

                    [String]
                    $dateStamp,

                    [String]
                    $regionName,

                    [String]
                    $serviceName
                )
    
                $kSecret = [Text.Encoding]::UTF8.GetBytes("AWS4$($key)")
                $kDate = HmacSHA256 -data $dateStamp -key $kSecret    
                $kRegion = HmacSHA256 -data $regionName -key $kDate
                $kService = HmacSHA256 -data $serviceName -key $kRegion
                $kSigning = HmacSHA256 -data "aws4_request" -key $kService

                return $kSigning # return of signing key as byte array

            }

            function get-amzdatestamp {
                $date = (Get-Date).ToUniversalTime().ToString("yyyyMMddTHHmmssZ")
                return $date
            }

            function get-datestamp {
                $date = (Get-Date).ToUniversalTime().ToString('yyyyMMdd')
                return $date
            }

            function get-amzkeys {
                param (
                    $role
                )

                try {
                    $uri = "http://169.254.169.254/latest/meta-data/iam/security-credentials"
                    $localIamRole = Invoke-RestMethod -uri $uri -Method Get

                    if (!($role)) {
                        $role = $localIamRole
                    }

                    if ($role -ne $localIamRole) {
                        throw "The defined role: $role doesn't match the value at $uri"
                    }

                    $uri = "http://169.254.169.254/latest/meta-data/iam/security-credentials/$role" 
                    $result = Invoke-RestMethod -uri $uri -Method Get -ContentType "application/json"
                    $roledata = $result
                }
                catch {
                    $_
                }

                return $roledata
            }

            $iamData = get-amzkeys -role $AwsIAMRole
    
            $accesskey = $iamdata.AccessKeyId
            $secretkey = $iamdata.SecretAccessKey
            $x_amz_security_token = $iamdata.Token

            $dateStamp = get-datestamp
            $x_amz_date = get-amzdatestamp

            # Build AWS Host if not passed
            if ($awsHost -eq $null) {
                $awsHostString = New-Object System.Text.StringBuilder
                $awsHostString.Append($Service) | Out-Null
                
                if ($Region -ne $null) {
                    $awsHostString.Append(".$Region") | Out-Null
                }
                
                $awsHostString.Append(".amazonaws.com") | Out-Null
                $awsHost = $awsHostString.ToString()
            }

            # Followed https://docs.aws.amazon.com/general/latest/gr/sigv4-signed-request-examples.html#sig-v4-examples-post
            # To create this script

            # ************* TASK 1: CREATE A CANONICAL REQUEST *************
            # http://docs.aws.amazon.com/general/latest/gr/sigv4-create-canonical-request.html


            # Step 1 is to define the verb (GET, POST, etc.)--already done.
            # Set in other places

            # Step 2: Create canonical URI--the part of the URI from domain to query 
            # string (use '/' if no path)
            $canocial_uri = '/'

            ## Step 3: Create the canonical query string. In this example, request
            # parameters are passed in the body of the request and the query string
            # is blank.
            if ($null -ne $awsQueryString) {
                $canonicalQuerystring = $awsQueryString
            }
            else {
                $canonicalQuerystring = ""
            }

            # Step 4: Create the canonical headers and signed headers. Header names
            # must be trimmed and lowercase, and sorted in code point order from
            # low to high. Note that there is a trailing \n.
            $canonical_headerData = New-Object System.Text.StringBuilder
            $headerData = New-Object System.Collections.Hashtable

            $SignedHeaders -split ";" | foreach {
                $name = if ($_ -eq "host") {
                    "awsHost"
                }
                else {
                    $_.replace("-","_")
                }

                $value = Get-Variable -Name $name -ValueOnly
                $canonical_headerData.Append("$_" + ":$value`n") | Out-Null
                $headerData.Add("$_",$value)
            }

            $canonical_headers = $canonical_headerData.ToString()

            # Step 5: Create the list of signed headers. This lists the headers
            # in the canonical_headers list, delimited with ";" and in alpha order.
            # Note: The request can include any headers; canonical_headers and
            # signed_headers lists those that you want to be included in the 
            # hash of the request. "Host" and "x-amz-date" are always required.
            # This is passed to the function and is used to build the canonical_headers

            # Step 6: Create payload hash (hash of the request body content). For GET
            # requests, the payload is an empty string ("").
            # Only Usefull if passing request parameters
            if ($awsRequestParmeters -eq $null) {
                $payloadData = ' '
            }
            else {
                $payloadData = $awsRequestParmeters
            }

            $payload_hash = getSHA256 -data $payloadData

            # Step 7: Combine elements to create canonical request
            $canonical_request = "$Method`n$canocial_uri`n$canonicalQuerystring`n$canonical_headers`n$SignedHeaders`n$payload_hash"

            # ************* TASK 2: CREATE THE STRING TO SIGN*************
            # Match the algorithm to the hashing algorithm you use, either SHA-1 or
            # SHA-256 (recommended)
            $credential_scope = "$dateStamp/$Region/$Service/aws4_request"
            $encoded_canonical_request = getSHA256 -data $canonical_request
            $string_to_sign = "$Algorithm`n$x_amz_date`n$credential_scope`n$encoded_canonical_request"
    
            # ************* TASK 3: CALCULATE THE SIGNATURE *************
            # Create the signing key using the function defined above.
            $signing_key = getSignatureKey -key $secretkey -dateStamp $datestamp -regionName $Region -serviceName $Service
    
            # Sign the string_to_sign using the signing_key
            $signature = HmacSHA256 -key $signing_key -data $string_to_sign -StringOut

            # ************* TASK 4: ADD SIGNING INFORMATION TO THE REQUEST *************
            # Put the signature information in a header named Authorization.

            $authorization_data = "$Algorithm Credential=$accesskey/$credential_scope, SignedHeaders=$SignedHeaders, Signature=$signature"
    
            $headerData.Add("authorization",$authorization_data)
    
            $out = @{
                HeaderData = $headerData
                RequestParameters = $awsRequestParmeters
            }
    
            Return $out
        }

        function AuthenticateTo-VaultAWSIam {
            <#
            .SYNOPSIS

            Retrieves a Vault token using IAM Auth
 
            .DESCRIPTION

            Retrieves a Vault token by creating a AWS V4 Signing Request and authenticating to AWS and passing the infomration to VAULT. Eliminates the need to have the Vault client installed in order to authenticate to vault on a windows system.
 
            .OUTPUTS

            A string of the Vault token
 
            .PARAMETER yamlRoleName

            The rolename of as defined in the yaml file in Github that is allowed to connect to Vault see below for example.
            Version: 1

            Notifications:
                Email: Example_DL@domain.com

            Admins:
                - ID: I123456
                Email: Example_User@domain.com

            Roles:
                ExampleRole: <----- yaml Role Name
                  AWS:
                    IAMRoles:
                    - Example-IAM-Role
                  AllowedDomains:
                    - example.domain.com

            .PARAMETER awsIAMRole

            The IAM Role attached to the EC2. Must match IAM role defined in the yalm file
            
            
            Version: 1

            Notifications:
                Email: Example_DL@domain.com

            Admins:
                - ID: I123456
                Email: Example_User@domain.com

            Roles:
                ExampleRole:
                  AWS:
                    IAMRoles:
                    - Example-IAM-Role <----- This should be the IAM role assigned to the EC2 instance
                  AllowedDomains:
                    - example.domain.com

            .PARAMETER awsRegion

            The AWS Region that you want to connect to.
            Default: Uses the output of: (Invoke-RestMethod -Uri http://169.254.169.254/latest/dynamic/instance-identity/document -Method Get).region
            If a region cannot be determined the function will stop and throw and error.

            .PARAMETER VaultURL

            The url for Vault.
            Default: https://vault.domain.com

            .PARAMETER VaultNamespace

            The namespace path.
            Example: namespace/ExampleSubFolder1
  
            .EXAMPLE

            $token = AuthenticateTo-VaultAWSIam -yamlRoleName "ExampleRole" -awsIAMRole "Example-IAM-Role" -awsRegion "us-west-2" -VaultURL "https://vault.domain.com" -VaultNamespace "namespace"
 
            .EXAMPLE

            $token = AuthenticateTo-VaultAWSIam -yamlRoleName "ExampleRole" -awsIAMRole "Example-IAM-Role" -VaultNamespace "namespace"
            #>
            [CmdletBinding()]
            param (
                [Parameter(Mandatory)]
                [string]
                $yamlRoleName,

                [Parameter()]
                [string]
                $awsIAMRole,
        
                [Parameter()]
                [string]
                $awsRegion = (Invoke-RestMethod -Uri http://169.254.169.254/latest/dynamic/instance-identity/document -Method Get -ErrorAction SilentlyContinue).region,
        
                [Parameter()]
                [uri]
                $VaultURL = "https://vault.domain.com",

                [Parameter(Mandatory)]
                [string]
                $VaultNamespace
            )
            Begin {
                #force TLS1.2
                [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

                function Set-Base64 {
                    param (
                        $Plaintext
                    )

                    $b = [System.Text.Encoding]::UTF8.GetBytes($Plaintext)
                    $64 = [System.Convert]::ToBase64String($b)

                    return $64
                }
            }
            Process {
                $AWSData = Build-ASWSignedRequest `
                    -AwsIAMRole $awsIAMRole `
                    -Service "sts" `
                    -Region $awsRegion `
                    -SignedHeaders "content-type;host;x-amz-date;x-amz-security-token" `
                    -Content_Type "application/x-www-form-urlencoded; charset=utf-8" `
                    -awsRequestParmeters "Action=GetCallerIdentity&Version=2011-06-15"
        
                #Build JSON Payload for Vault using Base-64 Encoding 
                $body = @{
                    role = $yamlRoleName
                    iam_http_request_method = "POST"
                    iam_request_headers = $(set-base64 -plaintext $($AWSData.HeaderData | ConvertTo-Json ))
                    iam_request_url = $(set-base64 -plaintext "https://sts.$awsRegion.amazonaws.com")
                    iam_request_body = $(set-base64 -plaintext $AWSData.RequestParameters)
                } | convertto-json

                #Send WebRequest to NameSpace AWS Auth using POST and JSON Data 
                
                try {
                    $uri = "$($VaultURL.AbsoluteUri)v1/$($vaultNamespace)/auth/aws/login"
                    $result = Invoke-RestMethod -uri $uri -Method POST -Body $body
                    $vaultToken = $result.auth.client_token
                }
                catch {
                    $vaultError = $(($_.ErrorDetails.Message.ToString() | ConvertFrom-Json).Errors)
                    $message = "Error message from Vault: $vaultError"
                    if ($false -eq [string]::IsNullOrWhiteSpace($vaultError)) {
                        Write-Log -Message $message -Level Error
                    }

                    $message = "Error with authenticating to Vault using the Automated IAM Auth process"
                    Write-Log -Message $message -Level Error -ThrowError
                }
        
            }
            End {
                return $vaultToken
            }

        }

