function List-VaultSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [string]
        $NameSpacePath,

        [parameter(Mandatory)]
        [string]
        $SecretPath,

        [parameter(Mandatory)]
        [uri]
        $VaultUrl,

        [parameter(Mandatory)]
        [hashtable]
        $VaultAuthenticationHeader
    )

    if ($SecretPath -notlike "secret/*") {
        $vaultSecretPath = "secret/$SecretPath"
    }
    else {
        $vaultSecretPath = $SecretPath
    }

    $uriBuilder = [System.UriBuilder]::new($VaultUrl)
    $uriBuilder.Path = "v1/$NameSpacePath/$vaultSecretPath/$SecretName"
    $uri =  $uriBuilder.Uri.ToString()

    $httpClient = [System.Net.Http.HttpClient]::new()
    $httpClient.BaseAddress = [uri]::new($uri)
    $httpClient.DefaultRequestHeaders.Add($VaultAuthenticationHeader.keys, $VaultAuthenticationHeader.Values)
    $result = $httpClient.SendAsync([System.Net.Http.HttpRequestMessage]::new([System.Net.Http.HttpMethod]::new("LIST"), $uri))
    
    if ($true -eq $result.Result.IsSuccessStatusCode) {
        $result.Result.Content.ReadAsStringAsync().Result
    }
    else {
        $result
    }
}
