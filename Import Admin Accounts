################
#Verify Log path
################

$logFileDirectoryTest = Test-Path -Path $LogFileDirectory
if ($logFileDirectoryTest -eq $false)
{
    New-Item -ItemType Directory -Path $logFileDirectory -Force
}

################
# 1. Authenticate to Thycotic
################

$thycoticAuthenticationArgs = @{
    ThycoticPassword =  $apiAccountPassword
    ThycoticUrl = $ThycoticURL
}

#attempt to authetnitcate using $DomainName\$apiAccountUsername. if no domain is set then it will only try $apiAccountUsername
$thycoticAuthenticationArgs["ThycoticUserName"] = [System.IO.Path]::Combine($DomainName,$apiAccountUsername)

try {
    $ThycoticAuthenticationTokenInfo = Get-ThycoticAuthenitcationToken @thycoticAuthenticationArgs
}
catch {
    $thycoticAuthenticationArgs["ThycoticUserName"] = $apiAccountUsername

    try {
        $ThycoticAuthenticationTokenInfo = Get-ThycoticAuthenitcationToken @thycoticAuthenticationArgs
    }
    catch {
        $message = "Was not able to loginto $($thycoticAuthenticationArgs['ThycoticUrl']) using $(if ($DomainName) {"either $([System.IO.Path]::Combine($DomainName,$apiAccountUsername)) or "})$apiAccountUsername. Please verify the username and password"
        Write-Log -Message $message -Level Error -Throw
    }
}

#Store the Thycotic Url and token info in a hashtable so we can use splating to pass the data to the api calls.
#Reduces the number of times we need to copy/paste `-ThycoticUrl $ThycoticURL -ThycoticAuthenticationToken $ThycoticAuthenticationTokenInfo` on each api call.
$thycoticApiCallInfo = @{
    ThycoticUrl = $ThycoticURL
    ThycoticAuthenticationToken = $ThycoticAuthenticationTokenInfo
}

################
# 2. Get Admin Folder ID
################

#Get information about the userAdminFolder
try {
    $userAdminFolderInfo = Get-ThycoticFolder -FolderName $userAdminFolderName @thycoticApiCallInfo | where {$_.folderName -eq $userAdminFolderName}
    
    if (!$userAdminFolderInfo) {
        $message = "Was not able to find the folder: $userAdminFolderName. Please verify the spelling of the folder and that $apiAccountUsername has access to the folder"
        Write-Log -Message $message -Level Error -Throw
    }
    else {
        # @($userAdminFolderInfo).Count is used to recast $userAdminFolderInfo to an object array to ensure proper count
        if (@($userAdminFolderInfo).Count -gt 1) {
            $message = "More than one folder was returned for $userAdminFolderName`:"
            Write-Log -Message $message -Level Warn
            $userAdminFolderInfo | foreach {
                Write-Log -Message $_.folderPath -Level Warn
            }

            $message = "Searching for `"$userAdminFolderName`" returned $(@($userAdminFolderInfo).Count) results. Please make sure that the spelling of the folder name is correct for `$userAdminFolderName"
            Write-Log -Message $message -Level Error -Throw
        }
    }
}
catch { 
    $message = "There was an error getting the folder: $userAdminFolderName"
    Write-Log -Message $message -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

################
# 3. Get Template ID
################

#default
try {
    $secretTemplateInfo = Get-ThycoticSecretTemplate -TemplateName $secretTemplateName @thycoticApiCallInfo | where {$_.name -eq $secretTemplateName}
    
    if (!$secretTemplateInfo) {
        $message = "Was not able to find the secret template: $secretTemplateName. Please verify the spelling of Secret Template"
        Write-Log -Message $message -Level Error -Throw
    }
    else {
        # @($secretTemplateInfo).Count is used to recast $secretTemplateInfo to an object array to ensure proper count
        if (@($secretTemplateInfo).Count -gt 1) {
            $message = "More than one secret template was returned for $secretTemplateName`:"
            Write-Log -Message $message -Level Warn
            $secretTemplateInfo | foreach {
                $message = "$($_.Name) (ID=$($_.id))"
                Write-Log -Message $message -Level Warn
            }

            $message = "Searching for `"$secretTemplateName`" returned $(@($secretTemplateInfo).Count) results. Please make sure that the spelling of the secret template name is correct for `$SecretTemplateName"
            Write-Log -Message $message -Level Error -Throw
        }
    }
}
catch {
    $message = "There was an error getting the template: $secretTemplateName"
    Write-Log -Message $message -quite:$false -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

################
# 4. Get thycoticAdmin group from Thycotic
################

#default
try {
    $thycoticAdminGroupInfo =  Get-ThycoticGroup -GroupName $adminGroupName @thycoticApiCallInfo | where {$_.name -eq $adminGroupName}

    if (!$thycoticAdminGroupInfo) {
        $message = "Was not able to find the group: $adminGroupName. Please verify the spelling of the group"
        Write-Log -Message $message -Level Error -Throw
    }
    else {
        # @($thycoticAdminGroupInfo).Count is used to recast $thycoticAdminGroupInfo to an object array to ensure proper count
        if (@($thycoticAdminGroupInfo).Count -gt 1) {
            $message = "More than one group was returned for $adminGroupName`:"
            Write-Log -Message $message -Level Warn
            $thycoticAdminGroupInfo | foreach {
                $message = "$($_.Name) (ID=$($_.id))"
                Write-Log -Message $message -Level Warn
            }

            $message = "Searching for `"$adminGroupName`" returned $(@($thycoticAdminGroupInfo).Count) results. Please make sure that the spelling of the group is correct for `$adminGroupName"
            Write-Log -Message $message -Level Error -Throw
        }
    }

}
catch {
    $message = "There was an error geting the group: $adminGroupName"
    Write-Log -Message $message -quite:$false -Level Error
    Write-Log -Message $_ -Level Error -Throw
}


################
# 5. Get all Admin secrets from Thycotic
################
#Get list of Thycotic User Admin Secrets
try {
    $allThycoticAdminSecrets = Find-ThycoticSecret -FolderId $userAdminFolderInfo.id -IncludeRestrictedSecrets:$true -IncludeSubFolders:$true @thycoticApiCallInfo
}
catch {
    $message = "Cannot get the $adminAccountSuffix Admin Secrets from Thycotic"
    Write-Log -Message $message -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

if (@($allThycoticAdminSecrets).count -eq 0) {
    $message = "No admin secrets returned from thycotic"
    Write-Log -Message $message -Level Error -Throw
}


################
# 6. Get all user accounts from Thycotic
################
#Get a list of all the Thycotic User Accounts
try {
    $thycoticUsers = Get-ThycoticUser @thycoticApiCallInfo | where {$_.domainId -ne -1 -and $_.userName -notlike "*sa" -and $_.userName -notlike "*-a"}
}
catch {
    $message = "Cannot get users from thycotic"
    Write-Log -Message $message -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

if (@($thycoticUsers).count -eq 0) {
    $message = "No users returned from thycotic"
    Write-Log -Message $message -Level Error -Throw
}


################
# 7. Get all admin user accounts from AD
################

#Get list of Admin Accounts in AD
try {
    $adminAccounts_AD = Get-ADUser -Filter "samAccountName -like '*$adminAccountSuffix'" -ResultSetSize $null | where {$_.enabled -eq $true}
}
catch {
    $message = "Was not able to pull a list of AD Admin Accounts"
    Write-Log -Message $message -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

#Get list of User Accounts in AD
try {
    $userAccounts_AD = Get-ADUser -Filter "EmployeeNumber -like '*' " -Properties EmployeeNumber,employeeType,DisplayName | where {$_.employeeType -ne "thycoticAdmin" -and $_.enabled -eq $true}
}
catch {
    $message = "Was not able to pull a list of AD User Accounts"
    Write-Log -Message $message -Level Error
    Write-Log -Message $_ -Level Error -Throw
}

################
# 9. Add Admin Secrets to Thycotic
################

#default
#This takes all the Thycotic users, and then returns only users who need admin accounts
#$accountsToProcess = $thycoticUsers | where {"$($_.userName)$adminAccountSuffix" -notin ($allThycoticAdminSecrets.name -replace ".*\\","") -and "$($_.userName)$adminAccountSuffix" -in $adminAccounts_AD.samAccountName}

#custom - Though this may become the defeault path since Admin accounts are I#'s and users are using first.last
$accountsToProcess = $userAccounts_AD | where {"$($_.EmployeeNumber)$adminAccountSuffix" -notin ($allThycoticAdminSecrets.name -replace ".*\\","") -and $_.SamAccountName -in $thycoticUsers.userName}

#All $userAccount variables are being customized
foreach ($userAccount in $accountsToProcess) {
    #creating a new session for each user to ensure we have a active token
    $entryThycoticApiCallInfo = @{
        ThycoticUrl = $ThycoticURL
        ThycoticAuthenticationToken = Get-ThycoticAuthenitcationToken @thycoticAuthenticationArgs
    }

    $userAdminUserName = "$($userAccount.EmployeeNumber)$adminAccountSuffix"
    $userAccount_Thycotic = $thycoticUsers | where {$_.userName -eq $userAccount.SamAccountName}

    if ($true -eq $testRun) {
        $message = "[$($userAccount.SamAccountName)] Test Run - Creating a Server Admin Secret for $userAdminUserName"
        Write-Log -Message $message -TextColor Green
    }
    else {
        ################
        # Create Secret
        ################ 
                
        $message = "[$($userAccount.SamAccountName)] Creating a Server Admin Secret for $userAdminUserName"                
        Write-Log -Message $message 

        $userAccountDisplayName = (($userAccount.displayName.Normalize([System.Text.NormalizationForm]::FormD)).ToCharArray() | 
            where {[Globalization.CharUnicodeInfo]::GetUnicodeCategory($_) -ne [Globalization.UnicodeCategory]::NonSpacingMark}) -join ""

        try {
            #default
            $secret = New-ThycoticSecret `
                        -SecretName "$DomainName\$userAdminUserName" `
                        -UserName $userAdminUserName `
                        -Domain $DomainName `
                        -InheritFolderPermissions:$false `
                        -InheritFolderSecretPolicy:$true `
                        -AccountOwner "$userAccountDisplayName - ($($userAccount.EmployeeNumber))" `
                        -SecretTemplateId $SecretTemplateInfo.id `
                        -FolderId $userAdminFolderInfo.id `
                        @entryThycoticApiCallInfo

            $message = "[$($userAccount.SamAccountName)] The secret $($secret.name) (ID $($secret.id)) was successfully created"
            Write-Log -Message $message -TextColor Green
        }

        catch {
            $message = "[$($userAccount.SamAccountName)] ----- Exception on creating the Secret -----"
            Write-Log -Message $message -Level Error
            Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error

            Continue
        }

        if ($true -eq $secret.checkOutEnabled)
        {
            ################
            # Check out the Secret
            ################ 

            Write-Log -Message "[$($userAccount.SamAccountName)] Checking out the secret: $($secret.name) (ID: $($secret.id))"

            try
            {
                CheckOut-ThycoticSecret -SecretID $secret.id @entryThycoticApiCallInfo | Out-Null
            }
            catch
            {
                $message = "[$($userAccount.SamAccountName)] ----- Exception on checking out the Secret: $($secret.name) (ID: $($secret.id)) -----"
                Write-Log -Message $message -Level Error
                Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error -Throw
            }
        }

        ################
        # Set Permissions on the Secret
        ################ 
                
        #Get existing permissions for secret
        $permissions = Get-ThycoticSecretPermission -SecretID $secret.id @entryThycoticApiCallInfo
        
        $groupPermissions = $permissions | where {$_.groupID}
        $userPermissions = $permissions | where {$_.userID}

        try {
            if ($thycoticAdminGroupInfo.id -notin $groupPermissions.groupId -or !($groupPermissions)) {
                # Add permissions for ThycoticAdmins Group to the secret
                $message = "[$($userAccount.SamAccountName)] Granting Owner permissions for the group $($thycoticAdminGroupInfo.name) to $($secret.name) (ID: $($secret.id))"
                Write-Log -Message $message

                Add-ThycoticSecretPermission -SecretID $secret.id -GroupId $thycoticAdminGroupInfo.id -AccessLevel Owner @entryThycoticApiCallInfo | Out-Null
            }

            if ($userAccount_Thycotic.id -notin $userPermissions.userId -or !($userPermissions)) {
                # Add permissions for user to the secret
                $message = "[$($userAccount.SamAccountName)] Granting Edit permissions for the user $($userAccount_Thycotic.displayName) to $($secret.name) (ID: $($secret.id))"
                Write-Log -Message $message

                Add-ThycoticSecretPermission -SecretID $secret.id -UserId $userAccount_Thycotic.id -AccessLevel Edit @entryThycoticApiCallInfo | Out-Null
            }
        }
        catch {
            $message = "[$($userAccount.SamAccountName)] ----- Error adding Permissions to the Secret: $($secret.name) (ID: $($secret.id)) -----"
            Write-Log -Message $message -Level Error
            Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error -Throw
        }

        try {
            $groupPermissions | where {$_.groupId -ne $thycoticAdminGroupInfo.id} | foreach {
                $message = "[$($userAccount.SamAccountName)] Removing $($_.secretAccessRoleName) permissions for the group $($_.knownAs) from the secret: $($secret.name) (ID: $($secret.id))"
                Write-Log -Message $message

                #Remove-ThycoticSecretPermission -SecretPermissionID $_.id @entryThycoticApiCallInfo | Out-Null
            }

            $userPermissions | where {$_.userId -ne $userAccount_Thycotic.id} | foreach {
                $message = "[$($userAccount.SamAccountName)] Removing permissions $($_.secretAccessRoleName) for the user $($_.knownAs) from the secret: $($secret.name) (ID: $($secret.id))"
                Write-Log -Message $message

                #Remove-ThycoticSecretPermission -SecretPermissionID $_.id @entryThycoticApiCallInfo | Out-Null
            }
        }
        catch {
            $message = "[$($userAccount.SamAccountName)] ----- Error removing Permissions from the Secret: $($secret.name) (ID: $($secret.id)) -----"
            Write-Log -Message $message -Level Error
            Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error -Throw
        }

        if ($secret.checkOutEnabled -eq $true) {
            ################
            # Check the Secret in
            ################ 

            # Beacuse the policy applied forces you to check out the account to modify it
            # and then it changes the password on check in, we are going to ignore the
            # POST /secrets/{id}/change-password method to change the password and instead
            # just the account out and back in

            $message = "[$($userAccount.SamAccountName)] Checking the secret $($secret.name) (ID: $($secret.id)) back in"
            Write-Log -Message $message
                        
            try {
                CheckIn-ThycoticSecret -SecretID $secret.id  -ForceCheckIn:$false @entryThycoticApiCallInfo | Out-Null
            }
            catch {
                try {
                    CheckIn-ThycoticSecret -SecretID $secret.id -ForceCheckIn:$true @entryThycoticApiCallInfo | Out-Null
                }
                catch {
                    $message = "[$($userAccount.SamAccountName)] ----- Exception on checking in $($secret.name) (ID: $($secret.id)) -----"
                    Write-Log -Message $message -Level Error
                
                    $message = "[$($userAccount.SamAccountName)] ----- THE ACCOUNT IS STILL CHECKED OUT. PLEASE MAKE SURE TO CHECK IT IN -----"
                    Write-Log -Message $message -Level Error
                
                    Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error -Throw
                }
            }
        }
    }
        
    Write-Log -Message "[$($userAccount.SamAccountName)] ========================================================="

    ################
    # Expire current Token
    ################

    Expire-ThycoticAuthenitcationToken @entryThycoticApiCallInfo | Out-Null
}

################
# 10. Remove Admin Secrets
################

$secretsToDelete = $allThycoticAdminSecrets | where {$_.name -replace "$DomainName\\","" -notin $adminAccounts_AD.SamAccountName}

foreach ($secret in $secretsToDelete) {
    if ($true -eq $testRun) {
        $message = "[$($secret.name)] ---- TEST RUN ---- The secret $($secret.name) (ID=$($secret.id)) would be deleted"
        Write-Log -Message $message -Level Warn
    }
    else {
        $entryThycoticApiCallInfo = @{
            ThycoticUrl = $ThycoticURL
            ThycoticAuthenticationToken = Get-ThycoticAuthenitcationToken @thycoticAuthenticationArgs
        }

        $message = "[$($secret.name)] Deleting the secret $($secret.name) (ID=$($secret.id))"
        Write-Log -Message $message -Level Warn

        try {
            Delete-ThycoticSecret -SecretID $secret.id @entryThycoticApiCallInfo | Out-Null
        }
        catch {
            $message = "[$($secret.name)] ----- Was not able to delte $($secret.name) (ID=$($secret.id)) -----"
            Write-Log -Message $message -Level Error
            Write-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error -ThrowWrite-Log -Message "[$($userAccount.SamAccountName)] $_" -Level Error
        }

        Expire-ThycoticAuthenitcationToken @entryThycoticApiCallInfo | Out-Null
    }
}
