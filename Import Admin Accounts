function Write-Log { 
    [CmdletBinding()] 
    Param     ( 
        [Parameter(Mandatory=$true, 
                    ValueFromPipelineByPropertyName=$true,
                    ValueFromPipeline = $true)]
        [string]
        $Message, 
 
        [string]
        $Path=$LogFilePath,

        [ValidateSet("Error","Warn","Info")]
        [string]
        $Level="Info",
        
        [Switch]
        $Throw,
        
        [Switch]
        $quite = $quite
    )
    
    DynamicParam {
        $paramDictionary = New-Object System.Management.Automation.RuntimeDefinedParameterDictionary
        #Name of the Parameter
        $paramName = "TextColor"
            
        #Create Attributecollection objects
        $attributeCollection = New-Object System.Collections.ObjectModel.Collection[System.Attribute]

        #Create and set the parameter Attributes (needed even if no attributes set)
        $paramAttribute = New-Object System.Management.Automation.ParameterAttribute
        $attributeCollection.Add($paramAttribute)
        
        #Generate and set the ValidateSet 
        $validationSet = @([consoleColor].GetEnumValues())
        $validationSetAttribute = New-Object System.Management.Automation.ValidateSetAttribute($validationSet)
        
        #Add the ValidationSet ot the attributes collection
        $attributeCollection.Add($validationSetAttribute)

        #Create the parameter and add it to the dynamic parameters
        $param = New-Object System.Management.Automation.RuntimeDefinedParameter($paramName, [string], $attributeCollection)
        $paramDictionary.Add($paramName,$param)

        return $paramDictionary
    }

    Begin {
            if ($PSBoundParameters[$paramName]) {
            $foregroundColor = @{
                ForegroundColor =$PSBoundParameters[$paramName]
            }
        }
    } 
    Process {
        # If attempting to write to a log file in a folder/path that doesn't exist create the file including the path. 
        if (!(Test-Path $Path)) { 
            Write-Verbose "Creating $Path." 
            $NewLogFile = New-Item $Path -Force -ItemType File 
        } 

        # Format Date for our Log File 
        $FormattedDate = Get-Date -Format "yyyy-MM-dd HH:mm:ss" 
 
        # Write message to error, warning, or verbose pipeline and specify $LevelText 
        switch ($Level) { 
            'Error' { 
                if ($false -eq $quite) {
                    if ($false -eq $Throw) {
                        Write-Host $Message -ForegroundColor Red
                    }
                    else {
                        Throw $Message
                    }
                }
                $LevelText = 'ERROR:' 
            } 
            'Warn' { 
                if ($false -eq $quite) {
                    Write-Host $Message -ForegroundColor Yellow
                }
                $LevelText = 'WARNING:' 
            } 
            'Info' {
                if ($false -eq $quite) {
                    Write-Host $Message @foregroundColor
                }
                $LevelText = 'INFO:' 
            } 
        } 

        # Write log entry to $Path 
        "$FormattedDate $LevelText $Message" | Out-File -FilePath $Path -Append 
    } 
    End { 
    } 
}

function Get-ThycoticAuthenitcationToken {
    param(
        [parameter(Mandatory)]
        [ValidateNotNullOrEmpty()]
        [String]
        $ThycoticUserName,

        [parameter(Mandatory)]
        [ValidateNotNullOrEmpty()]
        [String]
        $ThycoticPassword,

        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl
    )

    #force TLS1.2
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

    #Stores the creds to authenticate to Thycotic
    $invokeBody = @{
        username = $ThycoticUserName
        password = $ThycoticPassword
        grant_type = "password"
    }

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = '/oauth2/token'
    $uri = $uriBuilder.Uri.ToString()

    try {
        #Connects to the thycotic server and retrive the token
        $invokeResponse = Invoke-RestMethod -Uri $uri -Method Post -Body $invokeBody
    }
    catch {
        throw $_
    }
    
    $headerInfo = @{"Authorization" = "Bearer $($invokeResponse.access_token)"}

    $headerInfo
}

