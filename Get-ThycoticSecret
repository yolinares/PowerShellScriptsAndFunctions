function Get-ThycoticSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretID,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
    $uriBuilder.Path = "/api/v1/secrets/$SecretID"
    $uri = $uriBuilder.Uri.ToString()
    
    Invoke-RestMethod -Method Get -Uri $uri -Headers $ThycoticAuthenticationToken
}
