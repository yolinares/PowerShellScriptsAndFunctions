function CheckOut-ThycoticSecret {
    [CmdletBinding()]
    param (
        [parameter(Mandatory)]
        [int]
        $SecretID,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    $uriBuilder = [System.UriBuilder]::new($ThycoticUrl)
    $uriBuilder.Path = "/api/v1/secrets/$secretId/check-out"
    $uri = $uriBuilder.Uri.ToString()

    Invoke-RestMethod -Uri $uri -Method Post -Headers $ThycoticAuthenticationToken
}
