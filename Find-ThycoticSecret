function Find-ThycoticSecret {
    [CmdletBinding(DefaultParameterSetName="Default")]
    param (
        [parameter(ParameterSetName="byID")]
        [int]
        $SecretID,

        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.searchText")]
        [string]
        $Name,

        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.secretTemplateId")]
        [int]
        $SecretTemplateId,
        
        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.folderId")]
        [int]
        $FolderId,
        
        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.includeSubFolders")]
        [bool]
        $IncludeSubFolders,
        
        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.includeRestricted")]
        [bool]
        $IncludeRestrictedSecrets,

        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.includeActive")]
        [bool]
        $IncludeActiveSecrets,

        [parameter(ParameterSetName="byQuery")]
        [parameter(ParameterSetName="byID")]
        [Alias("q.filter.includeInactive")]
        [bool]
        $IncludeInactiveSecrets,

        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.siteId")]
        [int]
        $SiteID,

        [parameter(ParameterSetName="byQuery")]
        [Alias("q.filter.isExactMatch")]
        [bool]
        $ExactMatch,
        
        [parameter(ParameterSetName="byQuery")]
        [Alias("q.take")]
        [int]
        $MaxResults,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    if ($PSCmdlet.ParameterSetName -eq "byID") {
        $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
        $uriBuilder.Path = "/api/v1/secrets/$SecretID/summary"
        $uri = $uriBuilder.Uri.ToString()
    }
    else {
        $queryString = [Web.HttpUtility]::ParseQueryString('')

        $MyInvocation.MyCommand.Parameters.GetEnumerator() | 
            where {$_.Value.Aliases -like "q.*" -and $PSBoundParameters.Keys -contains $_.Key} |
            foreach {
                $queryString[$_.Value.Aliases[0].replace('q.','')] = $PSBoundParameters[$_.Key]
            }

        $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
        $uriBuilder.Path = '/api/v1/secrets'
        $uriBuilder.Query = $queryString.ToString()
        $uri = $uriBuilder.Uri.ToString()
    }

    try {
        $invokeResults = Invoke-RestMethod -Method Get -Uri $uri -Headers $ThycoticAuthenticationToken
    }
    catch {
        $_
    }
        
    if ($invokeResults) {
        if ($invokeResults.take -lt $invokeResults.total) {
            $PSBoundParameters.MaxResults = $invokeResults.total
            & $($PSCmdlet.MyInvocation.MyCommand.Name) @PSBoundParameters
        }
        else {
            switch ($PSCmdlet.ParameterSetName) {
                "byID" {$invokeResults}
                "byQuery" {
                    if ($true -eq $PSBoundParameters.ExactMatch) {
                        $invokeResults.records | where {$_.Name -eq $PSBoundParameters.Name}
                    }
                    else {
                        $invokeResults.records 
                    }
                }
            }
        }
    }
}
