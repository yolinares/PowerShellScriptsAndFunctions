function Delete-ThycoticGroup {
    [CmdletBinding()]
    param (
        [parameter(ParameterSetName="byID", Mandatory)]
        [int]
        $GroupID,

        [parameter(ParameterSetName="byName", Mandatory)]
        [Alias("q.filter.searchText")]
        [string]
        $GroupName,
        
        [parameter(Mandatory)]
        [ValidateScript({$null -ne $_.AbsoluteURI-and $_.Scheme -match "http|https"})]
        [uri]
        $ThycoticUrl,
        
        [parameter(Mandatory)]
        [hashtable]
        $ThycoticAuthenticationToken
    )

    Process {
        if ($PSCmdlet.ParameterSetName -eq "byName") {

            $queryString = [Web.HttpUtility]::ParseQueryString('')

            $MyInvocation.MyCommand.Parameters.GetEnumerator() | 
                where {$_.Value.Aliases -like "q.*" -and $PSBoundParameters.Keys -contains $_.Key} |
                foreach {
                    $queryString[$_.Value.Aliases[0].replace('q.','')] = $PSBoundParameters[$_.Key]
                }

            $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
            $uriBuilder.Path = '/api/v1/groups'
            $uriBuilder.Query = $queryString.ToString()
            $uri = $uriBuilder.Uri.ToString()

            try {
                $invokeResults = (Invoke-RestMethod -Method Get -Uri $uri -Headers $ThycoticAuthenticationToken) | where {$_.name -eq $GroupName}
            }
            catch {
                $_
            }
            
            if (@($invokeResults.records).count -eq 0) {
                throw "Couldn't find a group called $GroupName in Thycotic"
            }
            elseif (@($invokeResults.records).count -gt 1){
                throw "Found more than 1 group call$GroupName in Thycotic. Please use the groupID to delete the group."
            }
            else {
                $GroupID = $invokeResults.id
            }
        }
        
        $uriBuilder = [System.UriBuilder]::new($ThycoticUrl.ToString().TrimEnd("/"))
        $uriBuilder.Path = "/api/v1/groups/$GroupID"
        $uri = $uriBuilder.Uri.ToString()

        Invoke-RestMethod -Method Delete -Uri $uri -Headers $ThycoticAuthenticationToken -ContentType "application/json"
    }
}
